{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "verdiflow.vercel.app"
        }
      ],
      "destination": "https://verdiflowai.vercel.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "verdiflow-verdi-flow.vercel.app"
        }
      ],
      "destination": "https://verdiflowai.vercel.app/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "verdiflow-git-main-verdi-flow.vercel.app"
        }
      ],
      "destination": "https://verdiflowai.vercel.app/:path*",
      "permanent": true
    }
  ]
}
