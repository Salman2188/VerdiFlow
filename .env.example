# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL used for auth email links and OAuth callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Supabase Management API token for setup scripts
# SUPABASE_ACCESS_TOKEN=your-personal-access-token

# Optional: direct Postgres access for migration/seed scripts
# DATABASE_URL=postgresql://...

# Auth email note:
# Supabase's built-in email allows only 2 auth emails/hour project-wide.
# Custom SMTP (e.g. Resend) can be configured later after you own a sending domain.
# Check limits: npm run check:auth-rate-limits

# Meta / Instagram OAuth (Phase 2)
# META_APP_ID=your-meta-app-id
# META_APP_SECRET=your-meta-app-secret
# META_REDIRECT_URI=https://verdiflowai.vercel.app/api/integrations/instagram/callback
# META_OAUTH_STATE_SECRET=random-long-secret
